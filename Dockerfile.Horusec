FROM alpine:3.23

ARG HORUSEC_VERSION=2.8.0

# Supports Horusec source security scanning workflows.
RUN apk add --no-cache bash curl git make tar gzip ca-certificates
RUN curl --fail --silent --show-error --location \
    "https://github.com/ZupIT/horusec/releases/download/v${HORUSEC_VERSION}/horusec_linux_amd64" \
    --output /usr/local/bin/horusec && \
    chmod +x /usr/local/bin/horusec

WORKDIR /workspace

CMD ["/bin/sh"]
